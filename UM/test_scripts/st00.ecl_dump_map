void BossPatchouliEnd() {
    move_stop();
    enemy_flags_set(FLAG_NO_HITBOX | FLAG_NO_COLLISION);
    move_rand_interp_abs(90, Interp_DecelerateSlow, 0.6f);
    enemy_life_set(0);
+3000:
    enemy_delete();
}

