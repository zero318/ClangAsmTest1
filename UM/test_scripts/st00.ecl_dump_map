    enemy_lifebar_color(0, 3400.0f, 0xFFFFA080);
    enemy_lifebar_color(1, 1700.0f, 0xFFFFA080);
!*:
    nop();
    
+120:
    enemy_flags_clear(FLAG_NO_HITBOX);
    switch (PLAYER_SHOT) {
        case 0: // ReimuA -> Reimu
            FireEarthSignLavaCromlech();
            break;
        default: // ReimuB -> Sanae
            WaterWoodSignWaterElf();
            break;
        case 2: // MarisaA -> Marisa
            FireEarthSignLavaCromlech();
            break;
        case 1: // MarisaB -> Sakuya
            FireEarthSignLavaCromlech();
            break;
    }
}

