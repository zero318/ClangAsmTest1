void spinning_lasersA(int swap_colors, int call_number) {
    shooter_reset(0);
    shoot_aim_mode(0, CircleAimedMode);
    bullet_sprite(0, Ball, Red);
    bullet_count(0, (8 : 10 : 14 : 10), (1 : 1 : 1 : 2));
    bullet_speed(0, (1.5f : 2.0f : 2.4f : 3.0f), 1.2f);
    
    laser_clear_all();
    
    old_laser_line_init(
        1,
        Ball, swap_colors ? Red : Blue,
        QUARTER_PI, 0.0f,
        64.0f, 500.0f, 500.0f, 24.0f,
        (30 : 30 : 25 : 23), (70 : 70 : 58 : 54), (20 : 20 : 16 : 15),
        (30 : 30 : 25 : 23), 14
    );
    old_laser_line_init(
        2,
        Ball, swap_colors ? Red : Blue,
        QUARTER_PI, 0.0f,
        64.0f, 500.0f, 500.0f, 24.0f,
        (30 : 30 : 25 : 23), (90 : 90 : 75 : 70), (20 : 20 : 16 : 15),
        (30 : 30 : 25 : 23), 14
    );
    shoot_offset(1, 0.0f, -12.0f);
    shoot_offset(2, 0.0f, -12.0f);
    
    old_laser_line_create(1, 1);
    shoot_angle(1, THREE_QUARTERS_PI, 0.0f);
    old_laser_line_create(1, 2);
    shoot_angle(1, -THREE_QUARTERS_PI, 0.0f);
    old_laser_line_create(1, 3);
    shoot_angle(1, -QUARTER_PI, 0.0f);
    old_laser_line_create(1, 4);
    
    float angle;
    set_float_difficulty(angle, FIVE_HUNDRED_TWENTIETH_PI, FOUR_HUNDRED_SIXTIETH_PI, THREE_ONE_HUNDRED_FIFTEENTHS_PI, NINE_THREE_THOUSAND_TWO_HUNDRED_TWENTIETHS_PI);
    laser_rotate(1, angle);
    laser_rotate(2, angle);
    laser_rotate(3, angle);
    laser_rotate(4, angle);
    
    float angle_baseA = -THREE_QUARTERS_PI;
    float angle_baseB;
    
    int duration;
    int first_stop;
    int second_spawn;
    int shoot_freq;
    set_int_difficulty(duration, 180, 180, 150, 140);
    set_int_difficulty(first_stop, 120, 120, 100, 93);
    set_int_difficulty(second_spawn, 60, 60, 50, 46);
    set_int_difficulty(shoot_freq, 60, 50, 40, 40);
    
    int i = 0;
    do {
        if (i == second_spawn) {
            old_laser_line_create(2, 5);
            shoot_angle(2, THREE_QUARTERS_PI, 0.0f);
            old_laser_line_create(2, 6);
            shoot_angle(2, -THREE_QUARTERS_PI, 0.0f);
            old_laser_line_create(2, 7);
            shoot_angle(2, -QUARTER_PI, 0.0f);
            old_laser_line_create(2, 8);
            angle = -angle;
            laser_rotate(5, angle);
            laser_rotate(6, angle);
            laser_rotate(7, angle);
            laser_rotate(8, angle);
            angle_baseB = THREE_QUARTERS_PI;
        }
        if (call_number) {
            unless (i % shoot_freq) {
                if (i < first_stop) {
                    shoot_offset_circle(0, angle_baseA, 64.0f);
                    shoot_now(0);
                    shoot_offset_circle(0, angle_baseA + rad(90), 64.0f);
                    shoot_now(0);
                    shoot_offset_circle(0, angle_baseA + rad(180), 64.0f);
                    shoot_now(0);
                    shoot_offset_circle(0, angle_baseA + rad(270), 64.0f);
                    shoot_now(0);
                }
                if (i >= second_spawn) {
                    shoot_offset_circle(0, angle_baseB, 64.0f);
                    shoot_now(0);
                    shoot_offset_circle(0, angle_baseB + rad(90), 64.0f);
                    shoot_now(0);
                    shoot_offset_circle(0, angle_baseB + rad(180), 64.0f);
                    shoot_now(0);
                    shoot_offset_circle(0, angle_baseB + rad(270), 64.0f);
                    shoot_now(0);
                }
            }
        }
        angle_baseA += angle;
        angle_baseB -= angle;
        i += 1;
+1:
    } while (duration--);
    return;
}

void spinning_lasersB(int swap_colors, int call_number) {
    shooter_reset(0);
    shoot_aim_mode(0, (CircleAimedMode : CircleAimedMode : FanAimedMode : FanAimedMode));
    bullet_sprite(0, Ball, Red);
    bullet_count(0, (1 : 1 : 2 : 2), 2);
    bullet_speed(0, (2.0f : 2.0f : 2.0f : 2.5f), 1.2f);
    shoot_angle(0, 0.0f, (0.0f : 0.0f : THIRTY_SECOND_PI : THIRTY_SECOND_PI));
    
    laser_clear_all();
    
    old_laser_line_init(
        1,
        Ball, swap_colors ? Red : Blue,
        QUARTER_PI, 0.0f,
        64.0f, 500.0f, 500.0f, 24.0f,
        (30 : 30 : 25 : 23), (70 : 70 : 58 : 54), (20 : 20 : 16 : 15),
        (30 : 30 : 25 : 23), 14
    );
    old_laser_line_init(
        2,
        Ball, swap_colors ? Red : Blue,
        QUARTER_PI, 0.0f,
        64.0f, 500.0f, 500.0f, 24.0f,
        (30 : 30 : 25 : 23), (90 : 90 : 75 : 70), (20 : 20 : 16 : 15),
        (30 : 30 : 25 : 23), 14
    );
    shoot_offset(1, 0.0f, -12.0f);
    shoot_offset(2, 0.0f, -12.0f);
    
    old_laser_line_create(1, 1);
    shoot_angle(1, THREE_QUARTERS_PI, 0.0f);
    old_laser_line_create(1, 2);
    shoot_angle(1, -THREE_QUARTERS_PI, 0.0f);
    old_laser_line_create(1, 3);
    shoot_angle(1, -QUARTER_PI, 0.0f);
    old_laser_line_create(1, 4);
    
    float angle;
    set_float_difficulty(angle, -FIVE_HUNDRED_TWENTIETH_PI, -FOUR_HUNDRED_SIXTIETH_PI, -THREE_ONE_HUNDRED_FIFTEENTHS_PI, -NINE_THREE_THOUSAND_TWO_HUNDRED_TWENTIETHS_PI);
    laser_rotate(1, angle);
    laser_rotate(2, angle);
    laser_rotate(3, angle);
    laser_rotate(4, angle);
    
    float angle_baseA = -THREE_QUARTERS_PI;
    float angle_baseB;
    
    int duration;
    int first_stop;
    int second_spawn;
    int shoot_freq;
    set_int_difficulty(duration, 180, 180, 150, 140);
    set_int_difficulty(first_stop, 120, 120, 100, 93);
    set_int_difficulty(second_spawn, 60, 60, 50, 46);
    set_int_difficulty(shoot_freq, 60, 50, 40, 40);
    
    int i = 0;
    do {
        if (i == second_spawn) {
            old_laser_line_create(2, 5);
            shoot_angle(2, THREE_QUARTERS_PI, 0.0f);
            old_laser_line_create(2, 6);
            shoot_angle(2, -THREE_QUARTERS_PI, 0.0f);
            old_laser_line_create(2, 7);
            shoot_angle(2, -QUARTER_PI, 0.0f);
            old_laser_line_create(2, 8);
            angle = -angle;
            laser_rotate(5, angle);
            laser_rotate(6, angle);
            laser_rotate(7, angle);
            laser_rotate(8, angle);
            angle_baseB = THREE_QUARTERS_PI;
        }
        if (call_number) {
            unless (i % shoot_freq) {
                if (i < first_stop) {
                    shoot_offset_circle(0, angle_baseA, 64.0f);
                    shoot_now(0);
                    shoot_offset_circle(0, angle_baseA + rad(90), 64.0f);
                    shoot_now(0);
                    shoot_offset_circle(0, angle_baseA + rad(180), 64.0f);
                    shoot_now(0);
                    shoot_offset_circle(0, angle_baseA + rad(270), 64.0f);
                    shoot_now(0);
                }
                if (i >= second_spawn) {
                    shoot_offset_circle(0, angle_baseB, 64.0f);
                    shoot_now(0);
                    shoot_offset_circle(0, angle_baseB + rad(90), 64.0f);
                    shoot_now(0);
                    shoot_offset_circle(0, angle_baseB + rad(180), 64.0f);
                    shoot_now(0);
                    shoot_offset_circle(0, angle_baseB + rad(270), 64.0f);
                    shoot_now(0);
                }
            }
        }
        angle_baseA += angle;
        angle_baseB -= angle;
        i += 1;
+1:
    } while (duration--);
    return;
}

void full_power_dummy() {
    item_drop_area(0.0f, 0.0f);
    item_bonus_count_set(BigPowerItem, 4);
    drop_item_rewards();
    enemy_delete();
}

void main() {
    enemy_flags_set(FLAG_INVINCIBLE | FLAG_INTANGIBLE | FLAG_NO_DELETE);
+1:
    chapter_set(0);
    
    //msg_read(-2);
    //halt();
    
    enemy_create_abs("full_power_dummy", PLAYER_X, PLAYER_Y, 1, 0, 0);
    
    //enemy_create_abs("BossPatchouliPhase1", 64.0, -32.0, 10000, 0, 0);
    //enemy_create_abs("enemy_test", 64.0, -32.0, 10000, 0, 0);
    
    halt();
}

